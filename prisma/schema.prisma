generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma/client"
}

datasource db {
  provider = "postgresql" // change if you're using mysql/sqlite
}

model Session {
  id          String     @id @default(cuid())
  title       String?
  description String?

  questions   Question[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Question {
  id         String   @id @default(cuid())
  title      String
  question   String
  isAnswered Boolean  @default(false)

  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])

  answers    Answer[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Answer {
  id      String @id @default(cuid())
  content String

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId])
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String // store hashed password (bcrypt/argon2 only)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}